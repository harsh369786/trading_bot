# Broker API Credentials
BROKER_API_KEY=your_broker_api_key_here
BROKER_ACCESS_TOKEN=your_broker_access_token_here

# Angel One credentials (only required for live/real-data feed)
ANGEL_CLIENT_ID=your_angel_client_id
ANGEL_PASSWORD=your_angel_password
ANGEL_TOTP_SECRET=your_totp_base32_secret

# WebSocket feed URL
# Use mock:// for paper trading (no real connection needed)
# Use angelone:// for real Angel One SmartAPI feed
BROKER_WS_URL=mock://

# Trading mode — set to "live" ONLY when paper_mode=false AND you accept real order risk
# Default is "paper" (bot will refuse live orders unless this is explicitly set)
TRADING_MODE=paper

# Email EOD reports
REPORT_CHANNEL=email
NOTIFY_EMAIL_FROM=your_email@example.com
NOTIFY_EMAIL_PASSWORD=your_app_password_here
NOTIFY_EMAIL_TO=destination_email@example.com
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587

# Alternate supported names
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_app_password_here
# EMAIL_FROM=your_email@example.com
# EMAIL_TO=destination_email@example.com

# Telegram Notification Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Redis
REDIS_URL=redis://localhost:6379/0

# Historical Data Path
HISTORICAL_DATA_DIR=data/historical
